{
  "name": "finservco-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "FinServCo Financial Services Platform - Monorepo",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev:accounts": "npm run dev --workspace=services/account-service",
    "dev:transactions": "npm run dev --workspace=services/transaction-service",
    "dev:risk": "npm run dev --workspace=services/risk-engine",
    "dev:notifications": "npm run dev --workspace=services/notification-service",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  }
}
